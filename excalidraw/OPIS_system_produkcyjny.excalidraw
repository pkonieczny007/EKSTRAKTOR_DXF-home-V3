      "seed": 2005378845,
      "version": 3,
      "versionNonce": 991199059,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114297536,
      "link": null,
      "locked": false,
      "text": "Każdy detal dostaje kategorię trudności: łatwy / średni / trudny /\nczłowiek. Kategoria decyduje o głębokości kontroli i o tym, czy wynik\nidzie prosto na laser, czy do przeglądu.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Każdy detal dostaje kategorię trudności: łatwy / średni / trudny / człowiek. Kategoria decyduje o głębokości kontroli i o tym, czy wynik idzie prosto na laser, czy do przeglądu.",
      "autoResize": false,
      "lineHeight": 1.25
    },
