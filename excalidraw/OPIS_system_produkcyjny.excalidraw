      "versionNonce": 1141068829,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "Wersjonowany w git. Zmiany TYLKO przez merge zasad, które przeszły\nsystem testowy.",
