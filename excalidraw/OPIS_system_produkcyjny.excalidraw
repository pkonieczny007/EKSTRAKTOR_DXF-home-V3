    {
      "id": "2_qJR2dXXRB1njUhwqnTA",
      "type": "text",
      "x": 346.6607615908425,
      "y": 4706.895730912314,
      "width": 748,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
