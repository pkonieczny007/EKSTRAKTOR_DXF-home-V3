      "seed": 1543016029,
      "version": 3,
      "versionNonce": 862456477,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "Bramki kontroli (wszystkie deterministyczne, ezdxf):",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Bramki kontroli (wszystkie deterministyczne, ezdxf):",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "37vaHUNAxVxvwrb6HHLfr",
      "type": "text",
      "x": 3133.9940019182236,
      "y": 4619.515024851815,
      "width": 748,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2w",
      "roundness": null,
      "seed": 1751372275,
      "version": 3,
      "versionNonce": 518601139,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "liczba konturów zamkniętych: wejście vs. wyjście (musi się zgadzać),",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "liczba konturów zamkniętych: wejście vs. wyjście (musi się zgadzać),",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "fZoRw76R0x4qhFhd-CT9a",
      "type": "text",
      "x": 3128.5140214494736,
      "y": 4642.015024851815,
      "width": 758.9599609375,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2x",
      "roundness": null,
      "seed": 502315709,
      "version": 3,
      "versionNonce": 178695933,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "liczba otworów — w tym nieokrągłych (polilinie zamknięte, prostokąty,\nfasole, owale), nie tylko CIRCLE,",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "liczba otworów — w tym nieokrągłych (polilinie zamknięte, prostokąty, fasole, owale), nie tylko CIRCLE,",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "fM08c5apgDxGZ-XvTrwBz",
      "type": "text",
      "x": 3199.9940019182236,
      "y": 4714.515024851815,
      "width": 616,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
