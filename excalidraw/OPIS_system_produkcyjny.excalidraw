      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "Maksimum skryptów, minimum AI. Każdy krok AI musi mieć skryptową bramkę\nkontrolną za sobą.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Maksimum skryptów, minimum AI. Każdy krok AI musi mieć skryptową bramkę kontrolną za sobą.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "UcMn0qWGfSvJ1saJ91Pw-",
      "type": "text",
      "x": 3150.4979081682236,
      "y": 4477.015024851815,
      "width": 714.9921875,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b2u",
      "roundness": null,
      "seed": 463197267,
      "version": 3,
      "versionNonce": 581121043,
      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "Pipeline: wejście → określenie typu → orkiestrator wybiera sposób\n(V1/V2/V3) → generowanie → bramki kontroli → decyzja.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pipeline: wejście → określenie typu → orkiestrator wybiera sposób (V1/V2/V3) → generowanie → bramki kontroli → decyzja.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "hF7tpyvFkaToEvZjhI39Q",
      "type": "text",
      "x": 3221.9940019182236,
      "y": 4549.515024851815,
      "width": 572,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
