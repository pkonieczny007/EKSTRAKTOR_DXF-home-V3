      "isDeleted": true,
      "boundElements": null,
      "updated": 1783114286864,
      "link": null,
      "locked": false,
      "text": "skala 1:1 i wymiary gabarytowe vs. rysunek referencyjny,",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "skala 1:1 i wymiary gabarytowe vs. rysunek referencyjny,",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "wZ3vAvVSoBABglsQFTHQA",
      "type": "text",
      "x": 3304.4940019182236,
      "y": 4749.515024851815,
      "width": 407,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
